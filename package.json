{
	"name": "plinius",
	"version": "0.4.0",
	"description": "Plinius - Exploratory AI Project",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"cli": "tsx src/cli.ts",
		"benchmark": "tsx src/cli.ts benchmark",
		"targets": "tsx src/cli.ts targets",
		"suites": "tsx src/cli.ts suites",
		"experiment": "tsx src/cli.ts experiment",
		"matrix": "tsx src/cli.ts matrix",
		"validate:suites": "tsx scripts/validate-suites.mts",
		"evaluate": "tsx src/cli.ts evaluate",
		"compare": "tsx src/cli.ts compare",
		"dev": "tsx src/cli.ts",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "PLINIUS_LIVE_VLLM=1 vitest run test/integration"
	},
	"bin": {
		"plinius": "./dist/cli.js"
	},
	"dependencies": {
		"@openrouter/sdk": "^0.1.11",
		"dotenv": "^17.2.3",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^4.1.10"
	}
}
